# Client-side API base used by the frontend app
# Keep this as /backend when the frontend should proxy requests through Next rewrites
NEXT_PUBLIC_API_URL=/backend

# Server-side rewrite target for /backend/* requests
# Use your real backend deployment URL in production
BACKEND_URL=http://localhost:3001

# Optional absolute backend URL for client-side direct requests when needed
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
