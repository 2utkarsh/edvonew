# Client-side API base used by the frontend app
# Keep this as /backend so the browser uses the same backend proxy path as /backend/admin
# Do not point this to an older deployment URL when the frontend should go through the shared rewrite
NEXT_PUBLIC_API_URL=/backend

# Server-side rewrite target for /backend/* requests
# Use your real backend deployment URL in production
BACKEND_URL=http://localhost:3001

# Optional absolute backend URL for server-side fetches and fallback resolution
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Live classroom configuration
# Required for the integrated LiveKit room used by /live-classroom/*
# LIVEKIT_URL can be a direct LiveKit websocket URL like wss://live.yourdomain.com
# or a same-origin proxy path such as wss://your-project.vercel.app/livekit when LIVEKIT_PROXY_TARGET is set.
LIVEKIT_URL=wss://your-livekit-server
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Optional same-origin proxy target for Vercel/frontends
# Example: if LIVEKIT_URL is wss://your-project.vercel.app/livekit,
# set LIVEKIT_PROXY_TARGET=https://real-livekit-host.example.com
LIVEKIT_PROXY_TARGET=
NEXT_PUBLIC_LIVEKIT_PROXY_TARGET=
