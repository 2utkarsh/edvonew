{
  "name": "edvo-backend-nextjs",
  "version": "1.0.0",
  "private": true,
  "description": "EDVO Learning Platform - Next.js Backend API",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "seed:admin": "npx tsx scripts/seed-admin.ts",
    "seed:courses": "npx tsx scripts/seed-courses.ts",
    "seed:events": "npx tsx scripts/seed-events.ts",
    "seed:all": "npm run seed:admin && npm run seed:courses && npm run seed:events",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^8.18.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
